rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid == 'a2uvKrLDoNVPOafbOOM8BlErxek1';
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isReception() {
      return userRole() == 'reception';
    }

    function isDoctor() {
      return userRole() == 'doctor';
    }

    function isStaff() {
      return isAdmin() || isReception() || isDoctor();
    }

    match /publicStatus/{bookingId} {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    match /publicQueues/{queueId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /doctors/{doctorId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /patients/{patientId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin() || isReception();
    }

    match /bookings/{bookingId} {
      allow read: if isStaff();
      allow create, update, delete: if false;
    }

    match /queues/{queueId} {
      allow read: if isStaff();
      allow create, update, delete: if false;
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin() || isReception();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
